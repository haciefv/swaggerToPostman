{
  "manifest_version": 3,
  "name": "Swagger to Postman",
  "version": "1.0.0",
  "description": "Generate a Postman Collection from any Swagger or OpenAPI specification in one click.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Swagger to Postman"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "scripting", "downloads", "storage", "offscreen"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "sandbox": {
    "pages": ["sandbox.html"]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self'",
    "sandbox": "sandbox allow-scripts; script-src 'self' 'unsafe-eval'; object-src 'self'"
  },
  "minimum_chrome_version": "116"
}
